generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ============================================
// ENUMS
// ============================================

enum Role {
  SUPER_ADMIN
  MANAGER
  DIRECTEUR
  DRH
  DAF
  DGA
  DG
  RESP_PAIE
  EMPLOYE
}

enum Motif {
  CREATION
  REMPLACEMENT
  RENFORCEMENT
  NOUVEAU_POSTE
  EXPANSION
}

enum TypeContrat {
  CDI
  CDD
  STAGE
  ALTERNANCE
  FREELANCE
}

enum Priorite {
  HAUTE
  MOYENNE
  BASSE
}

enum StatutDemande {
  BROUILLON
  SOUMISE
  EN_VALIDATION_MANAGER
  EN_VALIDATION_DIR
  EN_VALIDATION_DRH
  EN_VALIDATION_DAF
  EN_VALIDATION_DGA
  EN_VALIDATION_DG
  EN_VALIDATION_CONSEIL
  VALIDEE
  REJETEE
  ANNULEE
}

enum DecisionEtape {
  EN_ATTENTE
  VALIDEE
  REFUSEE
  MODIFIEE
}

enum CircuitType {
  TECHNICIEN
  EMPLOYE
  CADRE_DEBUTANT
  CADRE_CONFIRME
  CADRE_SUPERIEUR
  STRATEGIQUE
}

enum TypeEntretien {
  RH
  TECHNIQUE
  DIRECTION
}

enum DecisionEvaluationPE {
  CONFIRMATION
  PROLONGATION
  RUPTURE
  CHANGEMENT
}

enum StatutEvaluationPE {
  BROUILLON
  EN_VALIDATION_DIR
  EN_VALIDATION_DRH
  EN_VALIDATION_DAF
  EN_VALIDATION_DGA
  EN_VALIDATION_DG
  VALIDEE
  REJETEE
}

// ============================================
// MODELE DIRECTION
// ============================================

model Direction {
  id        String   @id @default(uuid())
  code      String   @unique
  nom       String
  actif     Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users    User[]
  demandes DemandeRecrutement[]

  @@map("directions")
}

// ============================================
// MODELE USER
// ============================================

model User {
  id                 String    @id @default(uuid())
  email              String    @unique
  password           String
  nom                String
  prenom             String
  role               Role
  poste              String?
  telephone          String?
  actif              Boolean   @default(true)
  mustChangePassword Boolean   @default(true)
  dernierConnexion   DateTime?

  directionId String?
  direction   Direction? @relation(fields: [directionId], references: [id])

  // Hiérarchie
  managerId String?
  manager   User?   @relation("ManagerEmployes", fields: [managerId], references: [id])
  employes  User[]  @relation("ManagerEmployes")

  // Dates
  dateArrivee    DateTime  @default(now())
  dateFinContrat DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations existantes
  demandesCrees   DemandeRecrutement[] @relation("CreateurDemandes")
  demandesManager DemandeRecrutement[] @relation("ManagerDemandes")
  validations     ValidationEtape[]

  evaluationsEmploye    EvaluationPE[]         @relation("EmployeEvaluations")
  evaluationsManager    EvaluationPE[]         @relation("ManagerEvaluations")
  evaluationValidations EvaluationValidation[] @relation("ActeurEvaluationValidations")

  entretiensRealises        Entretien[]                @relation("InterviewerEntretiens")
  disponibilitesInterviewer DisponibiliteInterviewer[]

  notifications Notification[]
  auditLogs     AuditLog[]

  @@map("users")
}

// ============================================
// MODELE CIRCUIT CONFIG
// ============================================

model CircuitConfig {
  id             String      @id @default(uuid())
  type           CircuitType @unique
  nom            String
  description    String?
  etapes         Json
  totalEtapes    Int
  delaiParDefaut Int         @default(48)
  actif          Boolean     @default(true)
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  demandes DemandeRecrutement[]

  @@map("circuit_configs")
}

// ============================================
// MODELE DEMANDE RECRUTEMENT
// ============================================

model DemandeRecrutement {
  id            String  @id @default(uuid())
  reference     String  @unique
  intitulePoste String
  description   String?
  justification String

  motif                Motif
  commentaireMotif     String?
  personneRemplaceeNom String?
  fonctionRemplacee    String?

  typeContrat TypeContrat
  priorite    Priorite

  budgetMin Decimal? @db.Decimal(10, 2)
  budgetMax Decimal? @db.Decimal(10, 2)

  dateSouhaitee DateTime
  statut        StatutDemande @default(BROUILLON)
  niveau        CircuitType   @default(CADRE_CONFIRME)

  circuitType     CircuitType?
  totalEtapes     Int?
  etapeActuelle   Int          @default(0)
  circuitConfigId String?

  valideeAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  createurId String
  createur   User   @relation("CreateurDemandes", fields: [createurId], references: [id])

  managerId String
  manager   User   @relation("ManagerDemandes", fields: [managerId], references: [id])

  directionId String?
  direction   Direction? @relation(fields: [directionId], references: [id])

  circuitConfig              CircuitConfig?             @relation(fields: [circuitConfigId], references: [id])
  validations                ValidationEtape[]
  offre                      OffreEmploi?
  disponibilites             Disponibilite[]
  disponibilitesInterviewers DisponibiliteInterviewer[]

  @@map("demandes")
}

// ============================================
// MODELE DISPONIBILITE INTERVIEWER
// ============================================

model DisponibiliteInterviewer {
  id         String             @id @default(uuid())
  userId     String
  user       User               @relation(fields: [userId], references: [id])
  demandeId  String
  demande    DemandeRecrutement @relation(fields: [demandeId], references: [id], onDelete: Cascade)
  date       DateTime
  heureDebut String
  heureFin   String
  reservee   Boolean            @default(false)
  createdAt  DateTime           @default(now())
  entretien  Entretien?

  @@map("disponibilites_interviewers")
}

// ============================================
// MODELE VALIDATION ETAPE
// ============================================

model ValidationEtape {
  id             String             @id @default(uuid())
  demandeId      String
  demande        DemandeRecrutement @relation(fields: [demandeId], references: [id], onDelete: Cascade)
  niveauEtape    Int
  acteurId       String
  acteur         User               @relation(fields: [acteurId], references: [id])
  decision       DecisionEtape      @default(EN_ATTENTE)
  commentaire    String?
  dateLimite     DateTime
  relanceEnvoyee Boolean            @default(false)
  dateDecision   DateTime?

  createdAt   DateTime     @default(now())
  relanceJobs RelanceJob[]

  @@map("validations_etapes")
}

// ============================================
// MODELE RELANCE JOB
// ============================================

model RelanceJob {
  id                String          @id @default(uuid())
  validationEtapeId String
  validationEtape   ValidationEtape @relation(fields: [validationEtapeId], references: [id], onDelete: Cascade)
  type              String
  datePrevue        DateTime
  executee          Boolean         @default(false)
  executeeAt        DateTime?

  createdAt DateTime @default(now())

  @@map("relance_jobs")
}

// ============================================
// MODELE DISPONIBILITE
// ============================================

model Disponibilite {
  id         String             @id @default(uuid())
  demandeId  String
  demande    DemandeRecrutement @relation(fields: [demandeId], references: [id], onDelete: Cascade)
  date       DateTime
  heureDebut String
  heureFin   String

  @@map("disponibilites")
}

// ============================================
// MODELE OFFRE EMPLOI
// ============================================

model OffreEmploi {
  id                  String      @id @default(uuid())
  reference           String      @unique
  intitule            String
  description         String?
  profilRecherche     String?
  competences         String[]
  fourchetteSalariale String?
  typeContrat         TypeContrat
  statut              String      @default("BROUILLON")

  datePublication DateTime?
  lienCandidature String?   @unique

  demandeId    String?             @unique
  demande      DemandeRecrutement? @relation(fields: [demandeId], references: [id])
  rhId         String
  candidatures Candidature[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("offres")
}

// ============================================
// MODELE CANDIDATURE 
// ============================================

model Candidature {
  id                    String   @id @default(uuid())
  reference             String   @unique
  nom                   String
  prenom                String
  email                 String
  telephone             String?
  cvUrl                 String
  cvTexte               String?
  scoreGlobal           Int?
  scoreExp              Int?
  competencesDetectees  String[]
  competencesManquantes String[]
  statut                String   @default("NOUVELLE")
  consentementRGPD      Boolean  @default(false)
  consentementIA        Boolean  @default(false)
  dateSoumission        DateTime @default(now())

  // FICHE DE RENSEIGNEMENT (pages 2,3,4)
  ficheRenseignementEnvoyee   Boolean   @default(false)
  ficheRenseignementEnvoyeeAt DateTime?
  ficheRenseignementRecue     Boolean   @default(false)
  ficheRenseignementRecueAt   DateTime?
  ficheRenseignementToken     String?   @unique
  ficheRenseignementData      Json?

  offreId    String?
  offre      OffreEmploi? @relation(fields: [offreId], references: [id])
  entretiens Entretien[]
  contrat    Contrat?     @relation("CandidatureContrat")

  @@map("candidatures")
}

// ============================================
// MODELE ENTRETIEN
// ============================================

model Entretien {
  id         String        @id @default(uuid())
  type       TypeEntretien
  date       DateTime
  heure      String
  lieu       String
  statut     String        @default("PLANIFIE")
  feedback   String?
  evaluation Int?

  candidatureId String
  candidature   Candidature @relation(fields: [candidatureId], references: [id])

  interviewerId String
  interviewer   User   @relation("InterviewerEntretiens", fields: [interviewerId], references: [id])

  disponibiliteId String?                   @unique
  disponibilite   DisponibiliteInterviewer? @relation(fields: [disponibiliteId], references: [id])

  @@map("entretiens")
}

// ============================================
// MODELE CONTRAT 
// ============================================

model Contrat {
  id          String      @id @default(uuid())
  reference   String      @unique
  typeContrat TypeContrat
  salaire     String
  dateDebut   DateTime
  dateFin     DateTime?
  statut      String      @default("BROUILLON")
  pdfUrl      String?

  // ✅ AJOUTER CETTE LIGNE
  donneesContrat Json?

  candidatureId String?       @unique
  candidature   Candidature?  @relation("CandidatureContrat", fields: [candidatureId], references: [id])
  evaluationPE  EvaluationPE?
  avenants      Avenant[]

  @@map("contrats")
}

// ============================================
// MODELE EVALUATION PE
// ============================================

model EvaluationPE {
  id        String @id @default(uuid())
  reference String @unique

  employeId String
  employe   User    @relation("EmployeEvaluations", fields: [employeId], references: [id])
  managerId String
  manager   User    @relation("ManagerEvaluations", fields: [managerId], references: [id])
  contratId String  @unique
  contrat   Contrat @relation(fields: [contratId], references: [id])

  dateDebut      DateTime
  dateFin        DateTime
  dateEvaluation DateTime @default(now())
  joursRestants  Int

  decision             DecisionEvaluationPE?
  dureeProlongation    Int?
  justificationRupture String?

  evaluationN1     String?
  commentaireN1    String?
  dateSoumissionN1 DateTime?

  evaluationN2   String?
  commentaireN2  String?
  dateDecisionN2 DateTime?

  evaluationN1Masquee Boolean @default(false)

  statut        StatutEvaluationPE @default(BROUILLON)
  etapeActuelle Int                @default(0)
  totalEtapes   Int                @default(5)

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  valideeAt DateTime?

  validations EvaluationValidation[]

  @@map("evaluations_pe")
}

// ============================================
// MODELE EVALUATION VALIDATION
// ============================================

model EvaluationValidation {
  id             String       @id @default(uuid())
  evaluationId   String
  evaluation     EvaluationPE @relation(fields: [evaluationId], references: [id], onDelete: Cascade)
  niveauEtape    Int
  role           String
  acteurId       String
  acteur         User         @relation("ActeurEvaluationValidations", fields: [acteurId], references: [id])
  decision       String       @default("EN_ATTENTE")
  commentaire    String?
  dateLimite     DateTime
  dateDecision   DateTime?
  relanceEnvoyee Boolean      @default(false)

  createdAt DateTime @default(now())

  @@map("evaluations_validations")
}

// ============================================
// MODELE AVENANT
// ============================================

model Avenant {
  id          String   @id @default(uuid())
  typeAvenant String
  date        DateTime
  description String

  contratId String
  contrat   Contrat @relation(fields: [contratId], references: [id])

  @@map("avenants")
}

// ============================================
// MODELE NOTIFICATION
// ============================================

model Notification {
  id         String    @id @default(uuid())
  type       String
  titre      String
  message    String
  lienAction String?
  lu         Boolean   @default(false)
  luAt       DateTime?

  destinataireId String
  destinataire   User    @relation(fields: [destinataireId], references: [id])
  entityType     String?
  entityId       String?

  createdAt DateTime @default(now())

  @@map("notifications")
}

// ============================================
// MODELE AUDIT LOG
// ============================================

model AuditLog {
  id               String  @id @default(uuid())
  action           String
  entityType       String
  entityId         String
  anciennesValeurs Json?
  nouvellesValeurs Json?
  ipAdresse        String?
  userAgent        String?
  details          String?

  acteurId String
  acteur   User   @relation(fields: [acteurId], references: [id])

  createdAt DateTime @default(now())

  @@map("audit_logs")
}
