generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ============================================
// ENUMS
// ============================================

enum Role {
  SUPER_ADMIN
  MANAGER
  DIRECTEUR
  DRH
  DAF
  DGA
  DG
  RESP_PAIE
}

enum Motif {
  CREATION
  REMPLACEMENT
  RENFORCEMENT
  NOUVEAU_POSTE
  EXPANSION
}

enum TypeContrat {
  CDI
  CDD
  STAGE
  ALTERNANCE
  FREELANCE
}

enum Priorite {
  HAUTE
  MOYENNE
  BASSE
}

enum StatutDemande {
  BROUILLON
  SOUMISE
  EN_VALIDATION_DIR
  EN_VALIDATION_DRH
  EN_VALIDATION_DAF
  EN_VALIDATION_DGA
  EN_VALIDATION_DG
  EN_VALIDATION_CONSEIL
  VALIDEE
  REJETEE
  ANNULEE
}

enum DecisionEtape {
  EN_ATTENTE
  VALIDEE
  REFUSEE
  MODIFIEE
}

enum CircuitType {
  TECHNICIEN
  EMPLOYE
  CADRE_DEBUTANT
  CADRE_CONFIRME
  CADRE_SUPERIEUR
  STRATEGIQUE
  PERSONNALISE
}

// ============================================
// MODÈLE DIRECTION (NOUVEAU)
// ============================================

model Direction {
  id        String   @id @default(uuid())
  code      String   @unique
  nom       String
  actif     Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users    User[]
  demandes DemandeRecrutement[]

  @@map("directions")
}

// ============================================
// MODÈLE USER (MODIFIÉ)
// ============================================

model User {
  id                 String    @id @default(uuid())
  email              String    @unique
  password           String
  nom                String
  prenom             String
  role               Role
  departement        String?
  poste              String?
  telephone          String?
  actif              Boolean   @default(true)
  mustChangePassword Boolean   @default(true)
  dernierConnexion   DateTime?

  // ⬇️ NOUVEAU : Direction rattachée ⬇️
  directionId String?
  direction   Direction? @relation(fields: [directionId], references: [id])

  twoFactorEnabled Boolean @default(false)
  twoFactorSecret  String?
  backupCodes      String?

  createdAt DateTime  @default(now()) @map("createdAt")
  updatedAt DateTime  @updatedAt @map("updatedAt")
  deletedAt DateTime? @map("deletedAt")

  createdById  String?
  createdBy    User?   @relation("UserCreation", fields: [createdById], references: [id])
  usersCreated User[]  @relation("UserCreation")

  demandesCrees DemandeRecrutement[] @relation("ManagerDemandes")
  validations   ValidationEtape[]

  evaluationsEmploye EvaluationPE[] @relation("EmployeEvaluations")
  evaluationsManager EvaluationPE[] @relation("ManagerEvaluations")
  entretiensRealises Entretien[]    @relation("InterviewerEntretiens")
  notifications      Notification[]
  auditLogs          AuditLog[]

  @@map("users")
}

model CircuitConfig {
  id             String      @id @default(uuid())
  type           CircuitType @unique
  nom            String
  description    String?
  seuilMin       Float?
  seuilMax       Float?
  etapes         Json
  totalEtapes    Int
  delaiParDefaut Int         @default(48)
  actif          Boolean     @default(true)
  createdBy      String?
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  demandes DemandeRecrutement[]

  @@map("circuit_configs")
}

// ============================================
// MODÈLE DEMANDE (MODIFIÉ)
// ============================================

model DemandeRecrutement {
  id            String        @id @default(uuid())
  reference     String        @unique
  intitulePoste String
  description   String?
  justification String
  motif         Motif
  typeContrat   TypeContrat
  priorite      Priorite
  budgetEstime  Decimal       @db.Decimal(10, 2)
  dateSouhaitee DateTime
  statut        StatutDemande @default(BROUILLON)

  circuitType     CircuitType?
  totalEtapes     Int?
  etapeActuelle   Int          @default(0)
  circuitConfigId String?

  valideeAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  managerId String
  manager   User   @relation("ManagerDemandes", fields: [managerId], references: [id])

  // ⬇️ NOUVEAU : Direction de la demande ⬇️
  directionId String?
  direction   Direction? @relation(fields: [directionId], references: [id])

  circuitConfig  CircuitConfig?    @relation(fields: [circuitConfigId], references: [id])
  validations    ValidationEtape[]
  offre          OffreEmploi?
  disponibilites Disponibilite[]

  @@map("demandes")
}

model ValidationEtape {
  id             String             @id @default(uuid())
  demandeId      String
  demande        DemandeRecrutement @relation(fields: [demandeId], references: [id], onDelete: Cascade)
  niveauEtape    Int
  acteurId       String
  acteur         User               @relation(fields: [acteurId], references: [id])
  decision       DecisionEtape      @default(EN_ATTENTE)
  commentaire    String?
  dateLimite     DateTime
  relanceEnvoyee Boolean            @default(false)
  dateDecision   DateTime?

  createdAt   DateTime     @default(now())
  relanceJobs RelanceJob[]

  @@map("validations_etapes")
}

model RelanceJob {
  id                String          @id @default(uuid())
  validationEtapeId String
  validationEtape   ValidationEtape @relation(fields: [validationEtapeId], references: [id], onDelete: Cascade)
  type              String
  datePrevue        DateTime
  executee          Boolean         @default(false)
  executeeAt        DateTime?

  createdAt DateTime @default(now())

  @@map("relance_jobs")
}

model Disponibilite {
  id         String             @id @default(uuid())
  demandeId  String
  demande    DemandeRecrutement @relation(fields: [demandeId], references: [id], onDelete: Cascade)
  date       DateTime
  heureDebut String
  heureFin   String

  @@map("disponibilites")
}

model OffreEmploi {
  id                  String      @id @default(uuid())
  reference           String      @unique
  intitule            String
  description         String?
  profilRecherche     String?
  competences         String[]
  fourchetteSalariale String?
  typeContrat         TypeContrat
  statut              String      @default("BROUILLON")
  canauxPublication   String[]
  datePublication     DateTime?

  demandeId    String?             @unique
  demande      DemandeRecrutement? @relation(fields: [demandeId], references: [id])
  rhId         String
  candidatures Candidature[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("offres")
}

model Candidature {
  id                    String   @id @default(uuid())
  reference             String   @unique
  nom                   String
  prenom                String
  email                 String
  telephone             String?
  cvUrl                 String
  cvTexte               String?
  scoreGlobal           Int?
  scoreExp              Int?
  competencesDetectees  String[]
  competencesManquantes String[]
  statut                String   @default("NOUVELLE")
  consentementRGPD      Boolean  @default(false)
  consentementIA        Boolean  @default(false)
  dateSoumission        DateTime @default(now())

  offreId    String
  offre      OffreEmploi @relation(fields: [offreId], references: [id])
  entretiens Entretien[]
  contrat    Contrat?

  @@map("candidatures")
}

model Entretien {
  id         String   @id @default(uuid())
  type       String
  date       DateTime
  heure      String
  lieu       String
  statut     String   @default("PLANIFIE")
  feedback   String?
  evaluation Int?

  candidatureId String
  candidature   Candidature @relation(fields: [candidatureId], references: [id])
  interviewerId String
  interviewer   User        @relation("InterviewerEntretiens", fields: [interviewerId], references: [id])

  @@map("entretiens")
}

model Contrat {
  id          String      @id @default(uuid())
  reference   String      @unique
  typeContrat TypeContrat
  salaire     String
  dateDebut   DateTime
  dateFin     DateTime?
  statut      String      @default("BROUILLON")
  pdfUrl      String?

  candidatureId String        @unique
  candidature   Candidature   @relation(fields: [candidatureId], references: [id])
  evaluationPE  EvaluationPE?
  avenants      Avenant[]

  @@map("contrats")
}

model EvaluationPE {
  id                 String   @id @default(uuid())
  dateDebut          DateTime
  dateFin            DateTime
  joursRestants      Int
  decision           String?
  commentaire        String?
  commentaireManager String?
  etapeActuelle      Int

  employeId String
  employe   User    @relation("EmployeEvaluations", fields: [employeId], references: [id])
  managerId String
  manager   User    @relation("ManagerEvaluations", fields: [managerId], references: [id])
  contratId String  @unique
  contrat   Contrat @relation(fields: [contratId], references: [id])

  @@map("evaluations_pe")
}

model Avenant {
  id          String   @id @default(uuid())
  typeAvenant String
  date        DateTime
  description String

  contratId String
  contrat   Contrat @relation(fields: [contratId], references: [id])

  @@map("avenants")
}

model Notification {
  id         String    @id @default(uuid())
  type       String
  titre      String
  message    String
  lienAction String?
  lu         Boolean   @default(false)
  luAt       DateTime?

  destinataireId String
  destinataire   User    @relation(fields: [destinataireId], references: [id])
  entityType     String?
  entityId       String?

  createdAt DateTime @default(now())

  @@map("notifications")
}

model AuditLog {
  id               String  @id @default(uuid())
  action           String
  entityType       String?
  entityId         String?
  anciennesValeurs Json?
  nouvellesValeurs Json?
  ipAdresse        String?
  userAgent        String?

  acteurId String
  acteur   User   @relation(fields: [acteurId], references: [id])

  createdAt DateTime @default(now())

  @@map("audit_logs")
}
