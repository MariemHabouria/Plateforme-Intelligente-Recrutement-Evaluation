{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "outDir": "./dist",
    "rootDirs": ["./src", "."],
    "strict": false,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "types": ["node"]
  },
  "include": ["src/**/*", "prisma.config.ts", "prisma/**/*"],  // ← add prisma/**/*
  "exclude": ["node_modules"],
  "ts-node": {                     // ← add this block
    "transpileOnly": true,
    "files": true
  }
}