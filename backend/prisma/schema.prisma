generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ============================================
// ENUMS
// ============================================

enum Role {
  SUPER_ADMIN
  MANAGER
  DIRECTEUR
  DRH
  DAF
  DGA
  DG
  RESP_PAIE
}

enum Motif {
  CREATION
  REMPLACEMENT
  RENFORCEMENT
  NOUVEAU_POSTE
  EXPANSION
}

enum TypeContrat {
  CDI
  CDD
  STAGE
  ALTERNANCE
  FREELANCE
}

enum Priorite {
  HAUTE
  MOYENNE
  BASSE
}

enum StatutDemande {
  BROUILLON
  SOUMISE
  EN_VALIDATION_MANAGER
  EN_VALIDATION_DIR
  EN_VALIDATION_DRH
  EN_VALIDATION_DAF
  EN_VALIDATION_DGA
  EN_VALIDATION_DG
  EN_VALIDATION_CONSEIL
  VALIDEE
  REJETEE
  ANNULEE
}

enum DecisionEtape {
  EN_ATTENTE
  VALIDEE
  REFUSEE
  MODIFIEE
}

enum CircuitType {
  TECHNICIEN
  EMPLOYE
  CADRE_DEBUTANT
  CADRE_CONFIRME
  CADRE_SUPERIEUR
  STRATEGIQUE
}


enum TypeEntretien {
  RH         // Planifié par le DRH, date libre
  TECHNIQUE  // Manager obligatoire, créneau depuis DisponibiliteInterviewer
  DIRECTION  // Directeur, uniquement pour CADRE_SUPERIEUR et STRATEGIQUE
}

// ============================================
// MODÈLE DIRECTION
// ============================================

model Direction {
  id        String   @id @default(uuid())
  code      String   @unique
  nom       String
  actif     Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users    User[]
  demandes DemandeRecrutement[]

  @@map("directions")
}

// ============================================
// MODÈLE USER
// ============================================

model User {
  id                 String    @id @default(uuid())
  email              String    @unique
  password           String
  nom                String
  prenom             String
  role               Role
  poste              String?
  telephone          String?
  actif              Boolean   @default(true)
  mustChangePassword Boolean   @default(true)
  dernierConnexion   DateTime?

  directionId String?
  direction   Direction? @relation(fields: [directionId], references: [id])

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  demandesCrees   DemandeRecrutement[] @relation("CreateurDemandes")
  demandesManager DemandeRecrutement[] @relation("ManagerDemandes")
  validations     ValidationEtape[]

  evaluationsEmploye EvaluationPE[] @relation("EmployeEvaluations")
  evaluationsManager EvaluationPE[] @relation("ManagerEvaluations")
  entretiensRealises Entretien[]    @relation("InterviewerEntretiens")

  // ✅ NOUVEAU : disponibilités pour entretiens (MANAGER, DIRECTEUR, DRH)
  disponibilitesInterviewer DisponibiliteInterviewer[]

  notifications Notification[]
  auditLogs     AuditLog[]

  @@map("users")
}

// ============================================
// MODÈLE CIRCUIT CONFIG
// ============================================

model CircuitConfig {
  id             String      @id @default(uuid())
  type           CircuitType @unique
  nom            String
  description    String?
  etapes         Json
  totalEtapes    Int
  delaiParDefaut Int         @default(48)
  actif          Boolean     @default(true)
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  demandes DemandeRecrutement[]

  @@map("circuit_configs")
}

// ============================================
// MODÈLE DEMANDE RECRUTEMENT
// ============================================

model DemandeRecrutement {
  id            String        @id @default(uuid())
  reference     String        @unique
  intitulePoste String
  description   String?
  justification String
  
  motif         Motif
  commentaireMotif String?
  personneRemplaceeNom String?
  fonctionRemplacee String?
  
  typeContrat   TypeContrat
  priorite      Priorite
  
  budgetMin     Decimal?      @db.Decimal(10, 2)
  budgetMax     Decimal?      @db.Decimal(10, 2)
  
  dateSouhaitee DateTime
  statut        StatutDemande @default(BROUILLON)

  niveau        CircuitType   @default(CADRE_CONFIRME)
  
  circuitType     CircuitType?
  totalEtapes     Int?
  etapeActuelle   Int          @default(0)
  circuitConfigId String?

  valideeAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  createurId   String
  createur     User   @relation("CreateurDemandes", fields: [createurId], references: [id])
  
  managerId    String
  manager      User   @relation("ManagerDemandes", fields: [managerId], references: [id])

  directionId  String?
  direction    Direction? @relation(fields: [directionId], references: [id])

  circuitConfig  CircuitConfig?    @relation(fields: [circuitConfigId], references: [id])
  validations    ValidationEtape[]
  offre          OffreEmploi?
  disponibilites Disponibilite[]

  // ✅ NOUVEAU : disponibilités des interviewers liées à cette demande
  disponibilitesInterviewers DisponibiliteInterviewer[]

  @@map("demandes")
}

// ============================================
// ✅ NOUVEAU MODÈLE : DISPONIBILITE INTERVIEWER
// ============================================
// Stocke les créneaux des interviewers (MANAGER, DIRECTEUR, DRH)
// liés à une demande de recrutement spécifique.
// Utilisé par le RH pour planifier les entretiens TECHNIQUE et DIRECTION.
// Pour l'entretien RH, la date est choisie librement par le DRH.

model DisponibiliteInterviewer {
  id         String   @id @default(uuid())

  // L'interviewer qui propose ce créneau (MANAGER, DIRECTEUR, DRH)
  userId     String
  user       User     @relation(fields: [userId], references: [id])

  // La demande à laquelle ce créneau est associé
  demandeId  String
  demande    DemandeRecrutement @relation(fields: [demandeId], references: [id], onDelete: Cascade)

  date       DateTime
  heureDebut String
  heureFin   String

  // Passe à true quand un entretien est planifié sur ce créneau
  reservee   Boolean  @default(false)

  createdAt  DateTime @default(now())

  // Un créneau ne peut être utilisé que pour un seul entretien
  entretien  Entretien?

  @@map("disponibilites_interviewers")
}

// ============================================
// MODÈLE VALIDATION ETAPE
// ============================================

model ValidationEtape {
  id             String             @id @default(uuid())
  demandeId      String
  demande        DemandeRecrutement @relation(fields: [demandeId], references: [id], onDelete: Cascade)
  niveauEtape    Int
  acteurId       String
  acteur         User               @relation(fields: [acteurId], references: [id])
  decision       DecisionEtape      @default(EN_ATTENTE)
  commentaire    String?
  dateLimite     DateTime
  relanceEnvoyee Boolean            @default(false)
  dateDecision   DateTime?

  createdAt   DateTime     @default(now())
  relanceJobs RelanceJob[]

  @@map("validations_etapes")
}

// ============================================
// MODÈLE RELANCE JOB
// ============================================

model RelanceJob {
  id                String          @id @default(uuid())
  validationEtapeId String
  validationEtape   ValidationEtape @relation(fields: [validationEtapeId], references: [id], onDelete: Cascade)
  type              String
  datePrevue        DateTime
  executee          Boolean         @default(false)
  executeeAt        DateTime?

  createdAt DateTime @default(now())

  @@map("relance_jobs")
}

// ============================================
// MODÈLE DISPONIBILITE (créneaux demande - entretien technique)
// ============================================

model Disponibilite {
  id         String             @id @default(uuid())
  demandeId  String
  demande    DemandeRecrutement @relation(fields: [demandeId], references: [id], onDelete: Cascade)
  date       DateTime
  heureDebut String
  heureFin   String

  @@map("disponibilites")
}

// ============================================
// MODÈLE OFFRE EMPLOI
// ============================================

model OffreEmploi {
  id                  String      @id @default(uuid())
  reference           String      @unique
  intitule            String
  description         String?
  profilRecherche     String?
  competences         String[]
  fourchetteSalariale String?
  typeContrat         TypeContrat
  statut              String      @default("BROUILLON")

  datePublication     DateTime?
  lienCandidature     String?     @unique
  
  demandeId    String?             @unique
  demande      DemandeRecrutement? @relation(fields: [demandeId], references: [id])
  rhId         String
  candidatures Candidature[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("offres")
}

// ============================================
// MODÈLE CANDIDATURE
// ============================================

model Candidature {
  id                    String   @id @default(uuid())
  reference             String   @unique
  nom                   String
  prenom                String
  email                 String
  telephone             String?
  cvUrl                 String
  cvTexte               String?
  scoreGlobal           Int?
  scoreExp              Int?
  competencesDetectees  String[]
  competencesManquantes String[]
  statut                String   @default("NOUVELLE")
  consentementRGPD      Boolean  @default(false)
  consentementIA        Boolean  @default(false)
  dateSoumission        DateTime @default(now())

  offreId     String?      // ✅ AJOUTER ? pour rendre optionnel
  offre       OffreEmploi? @relation(fields: [offreId], references: [id])  // ✅ AJOUTER ?
  entretiens  Entretien[]
  contrat     Contrat?

  @@map("candidatures")
}
// ============================================
// MODÈLE ENTRETIEN — CORRIGÉ
// ============================================

model Entretien {
  id         String        @id @default(uuid())

  // ✅ Enum TypeEntretien (RH | TECHNIQUE | DIRECTION)
  type       TypeEntretien

  date       DateTime
  heure      String
  lieu       String
  statut     String        @default("PLANIFIE")
  feedback   String?
  evaluation Int?

  candidatureId String
  candidature   Candidature @relation(fields: [candidatureId], references: [id])

  // Pour RH : interviewerId = DRH lui-même
  // Pour TECHNIQUE : interviewerId = MANAGER de la direction
  // Pour DIRECTION : interviewerId = DIRECTEUR
  interviewerId String
  interviewer   User        @relation("InterviewerEntretiens", fields: [interviewerId], references: [id])

  // ✅ NOUVEAU : créneau utilisé (null pour entretien RH — date libre)
  // Pour TECHNIQUE et DIRECTION : obligatoirement un créneau DisponibiliteInterviewer
  disponibiliteId String?                    @unique
  disponibilite   DisponibiliteInterviewer?  @relation(fields: [disponibiliteId], references: [id])

  @@map("entretiens")
}

// ============================================
// MODÈLE CONTRAT
// ============================================

model Contrat {
  id          String      @id @default(uuid())
  reference   String      @unique
  typeContrat TypeContrat
  salaire     String
  dateDebut   DateTime
  dateFin     DateTime?
  statut      String      @default("BROUILLON")
  pdfUrl      String?

  candidatureId String        @unique
  candidature   Candidature   @relation(fields: [candidatureId], references: [id])
  evaluationPE  EvaluationPE?
  avenants      Avenant[]

  @@map("contrats")
}

// ============================================
// MODÈLE EVALUATION PE
// ============================================

model EvaluationPE {
  id                 String   @id @default(uuid())
  dateDebut          DateTime
  dateFin            DateTime
  joursRestants      Int
  decision           String?
  commentaire        String?
  commentaireManager String?
  etapeActuelle      Int

  employeId String
  employe   User    @relation("EmployeEvaluations", fields: [employeId], references: [id])
  managerId String
  manager   User    @relation("ManagerEvaluations", fields: [managerId], references: [id])
  contratId String  @unique
  contrat   Contrat @relation(fields: [contratId], references: [id])

  @@map("evaluations_pe")
}

// ============================================
// MODÈLE AVENANT
// ============================================

model Avenant {
  id          String   @id @default(uuid())
  typeAvenant String
  date        DateTime
  description String

  contratId String
  contrat   Contrat @relation(fields: [contratId], references: [id])

  @@map("avenants")
}

// ============================================
// MODÈLE NOTIFICATION
// ============================================

model Notification {
  id         String    @id @default(uuid())
  type       String
  titre      String
  message    String
  lienAction String?
  lu         Boolean   @default(false)
  luAt       DateTime?

  destinataireId String
  destinataire   User    @relation(fields: [destinataireId], references: [id])
  entityType     String?
  entityId       String?

  createdAt DateTime @default(now())

  @@map("notifications")
}

// ============================================
// MODÈLE AUDIT LOG
// ============================================

model AuditLog {
  id               String  @id @default(uuid())
  action           String
  entityType       String
  entityId         String
  anciennesValeurs Json?
  nouvellesValeurs Json?
  ipAdresse        String?
  userAgent        String?
  details          String?

  acteurId String
  acteur   User   @relation(fields: [acteurId], references: [id])

  createdAt DateTime @default(now())

  @@map("audit_logs")
}
