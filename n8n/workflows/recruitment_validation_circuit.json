[{"updatedAt":"2026-06-21T15:17:02.972Z","createdAt":"2026-06-15T22:30:31.123Z","id":"vNV54OIh8jMouvWm","name":"Recruitment Validation Circuit copy","description":null,"active":true,"isArchived":false,"nodes":[{"parameters":{"httpMethod":"POST","path":"cf3b9299-10e8-480c-ab14-1a46206ed1ca","options":{}},"type":"n8n-nodes-base.webhook","typeVersion":2.1,"position":[0,0],"id":"e6cce62f-76d1-40de-b3ec-26e22784ff11","name":"Webhook","webhookId":"cf3b9299-10e8-480c-ab14-1a46206ed1ca"},{"parameters":{"url":"=http://localhost:5000/api/demandes/internal/{{ $json.body.demandeId }}","sendHeaders":true,"headerParameters":{"parameters":[{"name":"Authorization","value":"Bearer kilani-n8n-secret-2026"}]},"options":{}},"type":"n8n-nodes-base.httpRequest","typeVersion":4.4,"position":[224,0],"id":"ead37b7d-baf8-4be4-8dea-803b39b58a61","name":"HTTP Request"},{"parameters":{"jsCode":"const raw = $('Webhook').first().json;\nconst body = raw.body ?? raw;\nconst demande = $('HTTP Request').first().json.data;\n\nconst token = body.token;\n\nconsole.log('[n8n] Token recu du backend:', token);\nconsole.log('[n8n] URL de validation:', `http://localhost:5173/validation/${demande.id}?token=${token}`);\n\nif (!token) {\n  throw new Error('Aucun token recu du backend');\n}\n\n// DECISION (rejet ou validation finale)\nif (body.type === 'DECISION') {\n  const dateSouhaitee = new Date(demande.dateSouhaitee)\n    .toLocaleDateString('fr-TN', { day: '2-digit', month: '2-digit', year: 'numeric' });\n\n  return [{\n    json: {\n      type:           'DECISION',\n      decision:       body.decision,\n      demandeId:      demande.id,\n      reference:      demande.reference,\n      titre:          demande.intitulePoste,\n      departement:    demande.direction?.nom ?? 'N/A',\n      demandeurNom:   demande.createur?.nom ?? 'N/A',\n      demandeurEmail: demande.createur?.email ?? '',\n      niveauPoste:    body.niveauPoste,\n      budgetMin:      demande.budgetMin,\n      budgetMax:      demande.budgetMax,\n      etape:          body.etape,\n      totalEtapes:    body.totalEtapes,\n      roleValidateur: body.roleValidateur ?? 'N/A',\n      dateSouhaitee,\n      platformUrl:    `http://localhost:5173/validation/${demande.id}?token=${token}`,\n    }\n  }];\n}\n\n// NOTIFICATION validateur (flow normal)\nconst etape = body.etape ?? 1;\nconst roleActuel = body.roleActuel;\n\nif (!roleActuel) {\n  throw new Error(`roleActuel manquant dans le body pour etape ${etape}`);\n}\n\nconst totalEtapes = body.totalEtapes ?? demande.totalEtapes ?? 0;\nconst isLast = etape === totalEtapes;\nconst isRelance = body.isRelance ?? false;\n\nconst priorityColor = {\n  HAUTE:   { bg: '#fee2e2', text: '#dc2626' },\n  MOYENNE: { bg: '#fef3c7', text: '#d97706' },\n  BASSE:   { bg: '#dcfce7', text: '#16a34a' },\n};\nconst pColor = priorityColor[demande.priorite] || priorityColor.MOYENNE;\n\nconst dateSouhaitee = new Date(demande.dateSouhaitee)\n  .toLocaleDateString('fr-TN', { day: '2-digit', month: '2-digit', year: 'numeric' });\n\nreturn [{\n  json: {\n    type:           'NOTIFICATION',\n    demandeId:      demande.id,\n    reference:      demande.reference,\n    titre:          demande.intitulePoste,\n    departement:    demande.direction?.nom ?? 'N/A',\n    demandeurNom:   demande.createur?.nom ?? 'N/A',\n    demandeurEmail: demande.createur?.email ?? '',\n    niveauPoste:    body.niveauPoste,\n    budgetMin:      demande.budgetMin,\n    budgetMax:      demande.budgetMax,\n    typeContrat:    demande.typeContrat,\n    priorite:       demande.priorite,\n    prioriteBg:     pColor.bg,\n    prioriteText:   pColor.text,\n    justification:  demande.justification,\n    dateSouhaitee,\n    etape,\n    totalEtapes,\n    roleActuel,\n    isLast,\n    isRelance,\n    platformUrl: `http://localhost:5173/validation/${demande.id}?token=${token}`,\n  }\n}];"},"type":"n8n-nodes-base.code","typeVersion":2,"position":[448,0],"id":"e9614585-bc99-4a5a-a3bf-e3bf6ea014ea","name":"Code in JavaScript"},{"para